+                    </thead>
+                    <tbody>
+                        {data.rows.map((row, ri) => (
+                            <tr
+                                key={ri}
+                                className={ri % 2 === 0 ? "bg-white" : "bg-gray-50"}
+                            >
+                                {row.map((cell, ci) => (
+                                    <td
+                                        key={ci}
+                                        className="px-3 py-2 text-gray-700 border-b border-gray-100"
+                                    >
+                                        {cell}
+                                    </td>
+                                ))}
+                            </tr>
+                        ))}
+                    </tbody>
+                </table>
+            </div>
+        </div>
+    );
+}
