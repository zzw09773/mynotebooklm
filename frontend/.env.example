# E2E Test Environment Variables
# Copy this file to .env.test and fill in values before running Playwright tests.

# Frontend base URL (default: http://localhost:3100)
BASE_URL=http://localhost:3100

# Path to Chromium executable.
# Leave blank to let Playwright use its own installed browser (recommended).
# Override for custom Docker/CI environments.
CHROMIUM_PATH=

# Directory for E2E fixture files (uploads used in document tests).
# Leave blank to use the default: e2e/fixtures/files/
E2E_FIXTURE_DIR=

# Test account credentials
# These accounts must exist in the running backend.
E2E_USER=e2etest01
E2E_PASSWORD=testpass01
E2E_USER_B=e2etest02
E2E_PASSWORD_B=testpass02
